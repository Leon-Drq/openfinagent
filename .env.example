# finagent-studio environment variables
# Copy to `.env` and fill in the values you need. Anything you don't
# need can stay empty — the keyless providers (yfinance, sec_edgar)
# work without any of these.

# ---- Required for `agent` steps -----------------------------------------
# OpenAI API key (or any OpenAI-compatible gateway, e.g. Vercel AI Gateway)
OPENAI_API_KEY=

# Optional: point the OpenAI client at a different endpoint.
# Examples:
#   - Vercel AI Gateway: https://gateway.ai.vercel.com/v1/openai
#   - Local llama.cpp:   http://localhost:8080/v1
#   - Azure OpenAI:      https://<resource>.openai.azure.com/openai/deployments/<id>
# OPENAI_BASE_URL=

# ---- Optional providers --------------------------------------------------

# FRED (free, request at https://fred.stlouisfed.org/docs/api/api_key.html)
# FRED_API_KEY=

# QVeris managed network (sign up at https://qveris.ai)
# QVERIS_API_KEY=

# SEC EDGAR fair-use policy: identify yourself with a contact email.
# SEC_USER_AGENT=your-name your.email@example.com
